# Environnement d'exécution : development | production
NODE_ENV=production

# Port du serveur
PORT=3000

# --- Supabase (auth + données, self-hosted ou cloud) ---
# URL de la passerelle Kong de ton instance Supabase.
SUPABASE_URL=https://supabase.tondomaine.fr
# Clé anon/public (Project Settings → API). Le serveur n'utilise jamais de
# clé service_role : chaque requête est faite avec le jeton de l'utilisateur
# connecté, et les policies RLS (voir supabase/migrations/0001_init.sql)
# isolent les données par compte.
SUPABASE_ANON_KEY=

# --- Ne pas remplir à la main ---
# SESSION_SECRET (signature des cookies de session) et APP_ENCRYPTION_KEY
# (chiffrement des mots de passe d'application Gmail au repos) sont générés
# automatiquement à la première exécution du serveur.
#
# Chaque utilisateur crée son propre compte depuis /register.html (email +
# mot de passe, géré par Supabase Auth), puis renseigne SA PROPRE adresse
# Gmail + SON PROPRE mot de passe d'application dans Réglages
# (https://myaccount.google.com/apppasswords). Ces identifiants sont stockés
# chiffrés dans la table profiles, isolés par utilisateur via RLS.
#
# Le seul super administrateur autorisé est verrouillé dans la migration SQL
# (fonction handle_new_user) — voir supabase/migrations/0001_init.sql.
