# Adresse Gmail depuis laquelle les emails sont envoyés
GMAIL_USER=nom@gmail.com

# Mot de passe d'application Gmail (16 caractères, PAS ton mot de passe normal)
# À générer sur https://myaccount.google.com/apppasswords
# (nécessite la validation en 2 étapes activée sur le compte Google)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Environnement d'exécution : development | production
NODE_ENV=production

# Port du serveur
PORT=3000

# Origine autorisée à appeler l'API (CORS) en production, ex: https://mail.tutehau.com
APP_ORIGIN=http://localhost:3000

# --- Ne pas remplir à la main ---
# SESSION_SECRET, APP_USERNAME et APP_PASSWORD_HASH sont générés automatiquement :
# SESSION_SECRET à la première exécution du serveur, APP_USERNAME/APP_PASSWORD_HASH
# lors de la création du compte administrateur sur /login.html.
