# Adresse Gmail depuis laquelle les emails sont envoyés
GMAIL_USER=nom@gmail.com

# Mot de passe d'application Gmail (16 caractères, PAS ton mot de passe normal)
# À générer sur https://myaccount.google.com/apppasswords
# (nécessite la validation en 2 étapes activée sur le compte Google)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Environnement d'exécution : development | production
NODE_ENV=production

# Port du serveur
PORT=3000

# SMTP utilisé pour l'email d'activation de compte (pas pour l'envoi des
# emails de l'application, qui passe par GMAIL_USER ci-dessus)
SMTP_HOST=smtp.tondomaine.fr
SMTP_PORT=587
# 'true' seulement si le port est 465 (SSL implicite) ; sinon laisser 'false' (STARTTLS sur 587)
SMTP_SECURE=false
SMTP_USER=contact@tutehau.com
SMTP_PASS=

# --- Ne pas remplir à la main ---
# SESSION_SECRET, APP_USERNAME, APP_EMAIL, APP_PASSWORD_HASH et APP_ACTIVATED
# sont générés automatiquement : SESSION_SECRET à la première exécution du
# serveur, les autres lors de la création du compte administrateur sur
# /register.html puis de son activation par email.
